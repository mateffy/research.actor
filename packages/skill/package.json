{
  "name": "@research.actor/skill",
  "version": "0.5.0",
  "description": "Agent skill for research — teaches AI agents how to use research effectively",
  "homepage": "https://research.actor",
  "repository": {
    "type": "git",
    "url": "https://github.com/mateffy/research.actor.git",
    "directory": "packages/skill"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./skill": {
      "import": "./research-analyze/SKILL.md"
    }
  },
  "files": [
    "dist",
    "research-analyze",
    "README.md"
  ],
  "keywords": [
    "ai",
    "agent-skill",
    "agentskills",
    "research",
    "skill"
  ],
  "license": "MIT",
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm && bun run typecheck",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^22.0.0"
  }
}

{
  "name": "@cachelyze/cli",
  "version": "0.4.0",
  "description": "CLI for cachelyze — cached codebase analysis for AI agents",
  "homepage": "https://research.actor",
  "repository": {
    "type": "git",
    "url": "https://github.com/mateffy/research.actor.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "cachelyze": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm && bun run typecheck",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cachelyze/core": "workspace:*",
    "citty": "^0.1.6"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^22.0.0"
  }
}

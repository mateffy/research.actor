{
  "name": "@cachelyze/core",
  "version": "0.4.0",
  "description": "Core business logic for cachelyze — cached codebase analysis for AI agents",
  "homepage": "https://cachelyze.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/mateffy/cachelyze.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm && bun run typecheck",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^22.0.0"
  }
}

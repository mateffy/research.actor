{
  "name": "research.actor",
  "version": "0.5.0",
  "description": "Cached codebase analysis for AI coding agents — stop re-exploring, start caching.",
  "homepage": "https://research.actor",
  "repository": {
    "type": "git",
    "url": "https://github.com/mateffy/research.actor.git",
    "directory": "packages/research.actor"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "research": "./bin/research.actor.js"
  },
  "keywords": [
    "ai",
    "agent",
    "cache",
    "codebase",
    "analysis",
    "llm",
    "coding-agent",
    "opencode",
    "claude",
    "codex",
    "research"
  ],
  "license": "MIT",
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm && bun run typecheck",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@research.actor/core": "workspace:*",
    "@research.actor/cli": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^22.0.0"
  }
}
